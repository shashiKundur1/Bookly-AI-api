      "request": { "method": "GET", "url": "{{host}}/api/v1/books/{{ccBookId}}/content" },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('content returns 200', () => pm.response.to.have.status(200));",
              "const content = pm.response.json();",
              "pm.test('table of contents extracted', () => {",
              "  pm.expect(content.page_count).to.eql(952);",
