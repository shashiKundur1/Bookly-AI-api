    {
      "name": "34 Delete the uploaded smoke-test book",
      "request": { "method": "DELETE", "url": "{{host}}/api/v1/books/{{uploadedBookId}}" },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('uploadedBookId')) {",
              "  pm.execution.skipRequest();",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": ["pm.test('cleanup delete returns 204', () => pm.response.to.have.status(204));"]
          }
        }
      ]
    }
  ]
}
